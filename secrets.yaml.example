# ─────────────────────────────────────────────────────────────────────
# secrets.yaml.example — safe to commit to GitHub
#
# HOW TO USE:
#   1. Copy this file and rename the copy to "secrets.yaml"
#   2. Fill in your values in secrets.yaml
#   3. In esp32-sdm530.yaml switch the Option A lines to Option B (!secret ...)
#
# secrets.yaml is listed in .gitignore and will NOT be committed to git.
# ─────────────────────────────────────────────────────────────────────

# ── Wi-Fi ─────────────────────────────────────────────────────────────
# The ESPHome dashboard fills these in automatically when you add a new device.
wifi_ssid: "YourNetworkName"
wifi_password: "YourWifiPassword"

# ── Device-specific secrets ───────────────────────────────────────────
# Copy each value from the ESPHome dashboard: device → Edit
# (all three are auto-generated the first time you add the device)

# api → encryption → key
esphome_api_key: "PASTE_YOUR_API_KEY_HERE"

# ota → password
esphome_ota_password: "PASTE_YOUR_OTA_PASSWORD_HERE"

# wifi → ap → password  (fallback hotspot when Wi-Fi is unavailable)
esphome_ap_password: "PASTE_YOUR_FALLBACK_AP_PASSWORD_HERE"
